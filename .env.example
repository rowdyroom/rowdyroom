# Rowdy Room Enterprise Engine local environment
# Copy this file to .env.local locally. Do not commit real keys.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
YOUTUBE_API_KEY=

# Optional YouTube Songfinder Guard limits
YOUTUBE_SEARCH_DAILY_LIMIT=100
YOUTUBE_SEARCH_PEAK_PER_MINUTE=20

# Optional model overrides
OPENAI_MODEL=
ANTHROPIC_MODEL=
XAI_MODEL=
GEMINI_MODEL=

# Optional local model runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Supabase server connection (memory + authoritative Main 4 API)
# Keep the service-role key server-side. Never use it in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

