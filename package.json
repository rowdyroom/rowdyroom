{
  "name": "rowdyroom-enterprise-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Modular AI operating system for Rowdy Room.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "engine:build": "tsc -p tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "test:rumble-focus": "node --test tools/rumble/fix-setup-focus.test.mjs",
    "test:rumble-start-setup": "node --test tools/rumble/fix-start-setup-flow.test.mjs",
    "test:rumble-coin": "node --test tools/rumble/fix-coin-carryover.test.mjs",
    "test:rumble-turn-display": "node --test tools/rumble/fix-current-turn-display.test.mjs",
    "test:rumble-timer": "node --test tools/rumble/fix-timer-lifecycle.test.mjs",
    "test:rumble-turn-advancement": "node --test tools/rumble/fix-turn-advancement.test.mjs",
    "test:rumble-wheel": "node --test tools/rumble/fix-wheel-trigger.test.mjs",
    "test:rumble-buzzer": "node --test tools/rumble/fix-buzzer-trigger.test.mjs",
    "test:rumble-tv": "node --test tools/rumble/fix-tv-mode.test.mjs",
    "test:rumble-questions": "node --test tools/rumble/fix-built-in-question-bank.test.mjs",
    "rumble:focus:check": "node tools/rumble/fix-setup-focus.mjs --check",
    "rumble:focus:patch": "node tools/rumble/fix-setup-focus.mjs --apply",
    "rumble:focus:restore": "node tools/rumble/fix-setup-focus.mjs --restore",
    "rumble:start-setup:check": "node tools/rumble/fix-start-setup-flow.mjs --check",
    "rumble:start-setup:patch": "node tools/rumble/fix-start-setup-flow.mjs --apply",
    "rumble:start-setup:restore": "node tools/rumble/fix-start-setup-flow.mjs --restore",
    "rumble:coin:check": "node tools/rumble/fix-coin-carryover.mjs --check",
    "rumble:coin:patch": "node tools/rumble/fix-coin-carryover.mjs --apply",
    "rumble:coin:restore": "node tools/rumble/fix-coin-carryover.mjs --restore",
    "rumble:turn-display:check": "node tools/rumble/fix-current-turn-display.mjs --check",
    "rumble:turn-display:patch": "node tools/rumble/fix-current-turn-display.mjs --apply",
    "rumble:turn-display:restore": "node tools/rumble/fix-current-turn-display.mjs --restore",
    "rumble:timer:check": "node tools/rumble/fix-timer-lifecycle.mjs --check",
    "rumble:timer:patch": "node tools/rumble/fix-timer-lifecycle.mjs --apply",
    "rumble:timer:restore": "node tools/rumble/fix-timer-lifecycle.mjs --restore",
    "rumble:turn-advancement:check": "node tools/rumble/fix-turn-advancement.mjs --check",
    "rumble:turn-advancement:patch": "node tools/rumble/fix-turn-advancement.mjs --apply",
    "rumble:turn-advancement:restore": "node tools/rumble/fix-turn-advancement.mjs --restore",
    "rumble:wheel:check": "node tools/rumble/fix-wheel-trigger.mjs --check",
    "rumble:wheel:patch": "node tools/rumble/fix-wheel-trigger.mjs --apply",
    "rumble:wheel:restore": "node tools/rumble/fix-wheel-trigger.mjs --restore",
    "rumble:buzzer:check": "node tools/rumble/fix-buzzer-trigger.mjs --check",
    "rumble:buzzer:patch": "node tools/rumble/fix-buzzer-trigger.mjs --apply",
    "rumble:buzzer:restore": "node tools/rumble/fix-buzzer-trigger.mjs --restore",
    "rumble:tv:check": "node tools/rumble/fix-tv-mode.mjs --check",
    "rumble:tv:patch": "node tools/rumble/fix-tv-mode.mjs --apply",
    "rumble:tv:restore": "node tools/rumble/fix-tv-mode.mjs --restore",
    "rumble:questions:check": "node tools/rumble/fix-built-in-question-bank.mjs --check",
    "rumble:questions:patch": "node tools/rumble/fix-built-in-question-bank.mjs --apply",
    "rumble:questions:restore": "node tools/rumble/fix-built-in-question-bank.mjs --restore"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "connectors/*",
    "agents/*"
  ],
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
